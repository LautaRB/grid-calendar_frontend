---
import "../styles/global.css";
import RaceCard from "../components/RaceCard.astro";
import NextRaceCard from "../components/NextRaceCard.astro";
import CalendarMonth from "../components/CalendarMonth.astro";

const API_URL = import.meta.env.PUBLIC_API_URL;

let races: any[] = [];
let error: string | null = null;

try {
  const response = await fetch(`${API_URL}/races`);
  if (!response.ok) {
    throw new Error("Error al obtener las carreras");
  }
  const data = await response.json();
  races = data.races || [];
} catch (e) {
  error = e instanceof Error ? e.message : "Error inesperado";
}

const ahora = new Date();
const proximas = races.filter((r) => new Date(r.endDate) > ahora).slice(0, 4);
const todas = races;

const hoy = new Date();
const currentMonth = hoy.getMonth();
const currentYear = hoy.getFullYear();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>F1 - Calendario</title>

    <link
      rel="icon"
      type="image/png"
      href="/fav_icon/favicon-96x96.png"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/fav_icon/favicon.svg" />
    <link rel="shortcut icon" href="/fav_icon/favicon.ico" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/fav_icon/apple-touch-icon.png"
    />
    <meta name="apple-mobile-web-app-title" content="F1 - Calendario" />
    <link rel="manifest" href="/fav_icon/site.webmanifest" />
  </head>
  <body class="bg-gray-900 min-h-screen text-white">
    <header>
      <!-- ================= HEADER MÓVIL ================= -->
      <div
        class="relative bg-linear-to-r from-red-800 from-50% to-transparent p-4 shadow-lg overflow-visible block md:hidden"
      >
        <div class="flex flex-col items-center gap-3">
          <div class="text-center translate-y-14">
            <h1 class="text-2xl font-extrabold tracking-tight">
              Calendario F1
            </h1>
            <p class="text-red-100 mt-1 text-sm">
              Temporada {new Date().getFullYear()}
            </p>
          </div>
          <img
            src="/header/F1_car.png"
            alt="F1 Car"
            class="h-48 w-70 translate-y-19 drop-shadow-xl"
          />
        </div>
      </div>

      <!-- ================= HEADER ESCRITORIO ================= -->
      <div
        class="relative bg-linear-to-r from-red-800 from-50% to-transparent p-6 shadow-lg overflow-visible hidden md:block"
      >
        <div class="max-w-5xl mx-auto flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-extrabold tracking-tight">
              Calendario F1
            </h1>
            <p class="text-red-100 mt-1 text-base">
              Temporada {new Date().getFullYear()}
            </p>
          </div>
          <img
            src="/header/F1_car.png"
            alt="F1 Car"
            class="absolute bottom-17.5 right-100 h-90 w-150 translate-y-1/2 drop-shadow-xl"
          />
        </div>
      </div>
    </header>

    <main class="max-w-5xl mx-auto p-6">
      {/* Próximas carreras */}
      {
        proximas.length > 0 && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
              <span>⏱️</span> Próximas 4 carreras
            </h2>
            <div class="flex gap-4 overflow-x-auto pb-4 snap-x items-stretch">
              {proximas.map((race) => (
                <div class="snap-start shrink-0 w-72">
                  <NextRaceCard
                    name={race.name}
                    country={race.country}
                    circuitName={race.circuitName}
                    startDate={race.startDate}
                    endDate={race.endDate}
                    round={race.round}
                  />
                </div>
              ))}
            </div>
          </section>
        )
      }

      {/* Calendario mensual */}
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
          <span>🗓️</span> Calendario mensual
        </h2>
        <CalendarMonth races={races} year={currentYear} month={currentMonth} />
      </section>

      {/* Calendario completo */}
      <section>
        <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-2">
          <span>📅</span> Calendario {new Date().getFullYear()}
        </h2>

        {
          error ? (
            <div class="bg-red-900/50 border border-red-500 text-red-200 p-4 rounded-lg">
              <p class="font-bold">⚠️ Error</p>
              <p>{error}</p>
            </div>
          ) : todas.length === 0 ? (
            <div class="text-center py-12 text-gray-400">
              <p class="text-4xl mb-4">🏁</p>
              <p class="text-lg">No se encontraron carreras.</p>
              <p class="text-sm mt-2">
                Sincronizá tu backend con /api/races primero.
              </p>
            </div>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 auto-rows-fr">
              {todas.map((race) => (
                <RaceCard
                  name={race.name}
                  country={race.country}
                  circuitName={race.circuitName}
                  startDate={race.startDate}
                  endDate={race.endDate}
                  round={race.round}
                  season={race.season}
                />
              ))}
            </div>
          )
        }
      </section>
    </main>
  </body>
</html>
