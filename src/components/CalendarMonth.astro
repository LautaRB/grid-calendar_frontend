---
import { getMonthDays } from '../utils/calendar.js';

export interface Props {
  races: any[]; // lista de carreras de la temporada
  year: number;
  month: number; // 0-indexed
}

const { races, year, month } = Astro.props;

// Días con carrera (inicio y fin)
const raceDays = races.flatMap(race => {
  const start = new Date(race.startDate);
  const end = new Date(race.endDate);
  const days = [];
  for (let d = new Date(start); d <= end; d.setDate(d.getDate() + 1)) {
    if (d.getFullYear() === year && d.getMonth() === month) {
      days.push(d.getDate());
    }
    // Saltar al siguiente día sin mutar
    d = new Date(d);
  }
  return days;
});

const { firstDay, days } = getMonthDays(year, month);
const monthNames = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
---

<div class="bg-gray-800 rounded-xl p-4 border border-gray-700 shadow-lg">
  <h3 class="text-lg font-bold text-white mb-3">{monthNames[month]} {year}</h3>
  <div class="grid grid-cols-7 gap-1 text-center text-xs">
    <span class="text-red-400 font-semibold">Dom</span>
    <span class="text-gray-300">Lun</span>
    <span class="text-gray-300">Mar</span>
    <span class="text-gray-300">Mié</span>
    <span class="text-gray-300">Jue</span>
    <span class="text-gray-300">Vie</span>
    <span class="text-red-400 font-semibold">Sáb</span>

    {/* Espacios vacíos para alinear el primer día */}
    {Array.from({ length: firstDay }).map(() => (
      <div></div>
    ))}

    {days.map(({ day, isToday }) => {
      const hasRace = raceDays.includes(day);
      return (
        <div class={`py-1 rounded ${hasRace ? 'bg-red-600 text-white font-bold' : isToday ? 'bg-gray-600 text-white' : 'text-gray-400'}`}>
          {day}
        </div>
      );
    })}
  </div>
</div>